# Copy this file to .env and fill in values.
# Or use Doppler: see doppler.env.example and README → Doppler section.
# For Vercel: sync from Doppler or paste the same variables in Project → Settings → Environment Variables.

# ── MongoDB ───────────────────────────────────────────────────────
# Local Docker:  mongodb://127.0.0.1:27017/epl_ghana  (run: docker compose up -d)
# Atlas prod:    mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/epl_ghana?retryWrites=true&w=majority
DATABASE_URL=mongodb://127.0.0.1:27017/epl_ghana

# ── Payload / Next.js ─────────────────────────────────────────────
PAYLOAD_SECRET=change-me-to-a-long-random-string-at-least-32-chars
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
EPL_DEV_AUTO_SEED=false

# ── SEO / indexing ────────────────────────────────────────────────
# Canonical public origin used for <title>, canonical URLs, Open Graph,
# sitemap.xml and JSON-LD. Keep this as the real production domain even on
# Vercel previews so search engines are pointed at prod, not the preview URL.
NEXT_PUBLIC_SITE_URL=https://eplghana.org
# Gate indexing. Leave "false" everywhere except the live production domain.
# false  -> robots.txt disallows all + every page sends noindex,nofollow.
# true   -> normal robots.txt + sitemap, pages are indexable.
NEXT_PUBLIC_SITE_INDEXABLE=false

# ── Cloudflare R2 (Vercel production media) ───────────────────────
# R2 is NOT AWS S3 — it exposes an S3-compatible API. Use R2_* variable names.
# Create token: Cloudflare → R2 → Manage R2 API Tokens → Object Read & Write → bucket epl-media
R2_BUCKET=epl-media
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_CLIENT_UPLOADS=true
# Optional public CDN URL (R2 bucket → Settings → Public access):
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Legacy S3_* names still work if you already set them in Vercel/Doppler.

# ── Email ─────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@notifymes.app
EMAIL_FROM_NAME=EPL Ghana CMS
# Optional override for the logo shown in HTML emails (defaults to /assets/cropped-EPL-Ghana-logo.png):
# EMAIL_LOGO_URL=https://eplghana.org/assets/cropped-EPL-Ghana-logo.png
