# Upload to Doppler: pnpm doppler:upload  (auto-creates from .env if missing)
# doppler.env is gitignored — never commit real secrets.

DATABASE_URL=
PAYLOAD_SECRET=
NEXT_PUBLIC_SERVER_URL=
EPL_DEV_AUTO_SEED=false

# Cloudflare R2 (S3-compatible API — use R2_* names, not AWS S3)
R2_BUCKET=epl-media
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_CLIENT_UPLOADS=true
# Optional: R2 bucket → Settings → Public access
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=EPL Ghana CMS
